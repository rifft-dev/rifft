{
  "name": "rifft",
  "private": true,
  "version": "0.1.0",
  "description": "Rifft - cross-framework debugger for multi-agent AI systems",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @rifft/collector --filter @rifft/api --filter @rifft/web dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
