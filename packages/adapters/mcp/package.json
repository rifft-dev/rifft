{
  "name": "@rifft-dev/mcp",
  "version": "0.1.0",
  "description": "MCP adapter for Rifft",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rifft-dev/rifft.git",
    "directory": "packages/adapters/mcp"
  },
  "homepage": "https://github.com/rifft-dev/rifft#readme",
  "bugs": {
    "url": "https://github.com/rifft-dev/rifft/issues"
  },
  "keywords": [
    "mcp",
    "agents",
    "debugging",
    "observability"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@rifft-dev/rifft": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
